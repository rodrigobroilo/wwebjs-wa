# wwebjs-wa Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ==================== Server ====================

# API key for authenticating requests (required — generate with: openssl rand -hex 32)
API_KEY=change-me

# Port the server listens on
PORT=3100

# Max messages kept in the in-memory buffer
MAX_MESSAGES=1000

# ==================== Python Scripts ====================

# wwebjs-wa server URL
# Local: http://localhost:3100
# Remote (via Cloudflare Tunnel): https://wwebjs.yourdomain.com
WWEBJS_URL=http://localhost:3100

# Same API key as above
WWEBJS_API_KEY=change-me

# SQLite database path
WWEBJS_DB=whatsapp.db

# HTTP User-Agent string
USER_AGENT=wwebjs-wa-client/1.0

# ==================== Cloudflare Access (Optional) ====================
# Only needed if accessing wwebjs-wa via Cloudflare Tunnel with Access policies

# CF_ACCESS_CLIENT_ID=your-cf-client-id
# CF_ACCESS_CLIENT_SECRET=your-cf-client-secret

# ==================== Groq AI (Optional — for media processing) ====================
# Get a free API key at https://console.groq.com

# GROQ_API_KEY=your-groq-api-key

# Default language for Whisper transcription (ISO 639-1 code)
# WHISPER_LANGUAGE=en

# ==================== Bot Identity ====================
# Used by the polling script to identify messages directed at the bot

# Bot's WhatsApp phone number (digits only, no +)
BOT_PHONE=17385551234

# Bot's display name
BOT_NAME=My Bot

# Bot's internal LID (WhatsApp internal ID — check /health endpoint)
# BOT_LID=12345678901234@lid

# ==================== Owner ====================
# Owner's phone number and LID — bot only takes commands from this user

# OWNER_PHONE=15551234567
# OWNER_LID=12345678901234@lid
